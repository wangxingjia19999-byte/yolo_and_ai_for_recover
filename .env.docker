# ══════════════════════════════════════════════════════════════
# Docker 部署环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.docker .env
# ══════════════════════════════════════════════════════════════

# ── 数据库 ──────────────────────────────────────────────────
POSTGRES_PASSWORD=rehab123

# ── AI / LLM 配置 ───────────────────────────────────────────
OPENAI_API_KEY=sk-你的API密钥
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ── 摄像头 ──────────────────────────────────────────────────
# 0 = 默认USB摄像头, 或 RTSP 地址
CAMERA_SOURCE=0
CAPTURE_FPS=15
